# ============================================================
#  Salin file ini menjadi .env lalu isi nilainya
#  cp .env.example .env
# ============================================================

# ── PostgreSQL (Neon.tech / Supabase / Railway PostgreSQL) ──
# Salin connection string dari dashboard Neon atau Railway
# Format: postgresql://user:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://user:password@host:5432/tracking_db?sslmode=require

# ── Server ──────────────────────────────────────────────────
# Port akan otomatis diset oleh Railway, tidak perlu diubah
PORT=3000

# ── Environment ─────────────────────────────────────────────
NODE_ENV=production
